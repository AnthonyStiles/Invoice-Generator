<?xml version="1.0" encoding="UTF-8"?>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Light theme -->
    <Color x:Key="NearlyWhite">#F8F9FA</Color>
    <Color x:Key="MediumGrey">#4A4F59</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Red">#D32F2F</Color>

    <!-- Dark theme -->
    <Color x:Key="NearlyBlack">#0B0E14</Color>
    <Color x:Key="BlueGrey">#97A3B6</Color>
    <Color x:Key="NavyGrey">#161B22</Color>
    <Color x:Key="LightRed">#FF6B6B</Color>

</ResourceDictionary>