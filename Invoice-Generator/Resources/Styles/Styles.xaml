<?xml version="1.0" encoding="UTF-8"?>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Border" x:Key="CardStyle">
        <Setter Property="Stroke"
                Value="{AppThemeBinding Light={StaticResource MediumGrey}, Dark={StaticResource BlueGrey}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 4" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavyGrey}}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,8" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{AppThemeBinding Light={StaticResource MediumGrey}, Dark={StaticResource NearlyBlack}}"
                        Offset="0,2"
                        Radius="4"
                        Opacity="0.1" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource NearlyWhite}, Dark={StaticResource NearlyBlack}}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource MediumGrey}, Dark={StaticResource BlueGrey}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource MediumGrey}, Dark={StaticResource BlueGrey}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource MediumGrey}, Dark={StaticResource BlueGrey}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource MediumGrey}, Dark={StaticResource BlueGrey}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="SwipeItem">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Red}, Dark={StaticResource LightRed}}" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource NearlyWhite}, Dark={StaticResource NearlyBlack}}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource NearlyWhite}, Dark={StaticResource NearlyBlack}}" />
        <Setter Property="ForegroundColor"
                Value="{AppThemeBinding Light={StaticResource MediumGrey}, Dark={StaticResource BlueGrey}}" />
    </Style>

    <!-- <Style TargetType="ImageButton"> -->
    <!--     <Setter Property="Tint" -->
    <!--             Value="{AppThemeBinding Light={StaticResource NearlyWhite}, Dark={StaticResource NearlyBlack}}" /> -->
    <!-- </Style> -->
</ResourceDictionary>