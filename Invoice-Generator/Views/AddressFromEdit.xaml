<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Invoice_Generator.ViewModels"
             x:Class="Invoice_Generator.Views.AddressFromEdit"
             x:DataType="local:AddressFromEditViewModel">
    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="check" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>
    <Grid
        RowDefinitions="Auto, *"
        Padding="30"
        RowSpacing="30">
        <Label Text="Add details used for the from address." />
        <VerticalStackLayout Grid.Row="1" Spacing="20">
            <Entry x:Name="NameEntry"
                   Placeholder="Name"
                   Text="{Binding Address.Name}"
                   MaxLength="50"
                   ReturnType="Next"
                   ReturnCommand="{Binding Source={x:Reference Line1Entry}, Path=Focus}"
                   Loaded="OnEntryLoaded" />
            <Entry x:Name="Line1Entry"
                   Placeholder="Line 1"
                   MaxLength="50"
                   Text="{Binding Address.Line1}"
                   ReturnType="Next"
                   ReturnCommand="{Binding Source={x:Reference Line2Entry}, Path=Focus}" />
            <Entry x:Name="Line2Entry"
                   Placeholder="Line 2"
                   Text="{Binding Address.Line2}"
                   MaxLength="50"
                   ReturnType="Next"
                   ReturnCommand="{Binding Source={x:Reference PostCodeEntry}, Path=Focus}" />
            <Entry x:Name="PostCodeEntry"
                   Placeholder="Post Code"
                   MaxLength="8"
                   Text="{Binding Address.PostCode}"
                   ReturnType="Next"
                   ReturnCommand="{Binding Source={x:Reference EmailEntry}, Path=Focus}" />
            <Entry x:Name="EmailEntry"
                   Placeholder="Email"
                   Text="{Binding Address.Email}"
                   Keyboard="Email"
                   MaxLength="50"
                   ReturnType="Next"
                   ReturnCommand="{Binding Source={x:Reference PhoneEntry}, Path=Focus}" />
            <Entry x:Name="PhoneEntry"
                   Placeholder="Phone"
                   Text="{Binding Address.Phone}"
                   Keyboard="Telephone"
                   MaxLength="11"
                   ReturnType="Done"
                   ReturnCommand="{Binding SaveCommand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>