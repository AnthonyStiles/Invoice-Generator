<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Invoice_Generator.ViewModels"
             xmlns:models="clr-namespace:Invoice_Generator.Models"
             x:Class="Invoice_Generator.Views.AddressToSelector"
             x:DataType="local:AddressToSelectorViewModel"
             x:Name="AddressSelector">
    <Grid
        RowDefinitions="Auto, Auto, *"
        Padding="30"
        RowSpacing="30">
        <Label Text="Who is the invoice to?" />
        <Button Grid.Row="1"
                Text="Add New Details"
                Command="{Binding AddNewDetailsCommand}" />
        <CollectionView x:Name="AddressList"
                        ItemsSource="{Binding Addresses}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedAddress}"
                        SelectionChangedCommand="{Binding AddressChangedCommand}"
                        Grid.Row="2">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AddressToModel">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="{StaticResource Danger}"
                                           Command="{Binding BindingContext.DeleteAddressCommand, Source={x:Reference AddressSelector}}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border Style="{StaticResource CardStyle}">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                <Label Text="{Binding Line1}" Style="{StaticResource BodyText}" />
                                <Label Text="{Binding PostCode}" Style="{StaticResource BodyText}" />
                            </VerticalStackLayout>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>