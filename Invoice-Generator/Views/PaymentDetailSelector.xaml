<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Invoice_Generator.ViewModels"
             xmlns:models="clr-namespace:Invoice_Generator.Models"
             x:Class="Invoice_Generator.Views.PaymentDetailSelector"
             x:DataType="local:PaymentDetailSelectorViewModel"
             x:Name="PaymentDetailSelectorView">
    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="add" Command="{Binding AddNewDetailsCommand}" />
        <ToolbarItem Text="Skip"
                     Command="{Binding NavigateNextCommand }" />
    </ContentPage.ToolbarItems>
    <ContentView>
        <Grid
            RowDefinitions="Auto, *"
            Padding="30"
            RowSpacing="30">
            <Label Text="What details can the customer use to pay?" />
            <CollectionView x:Name="PaymentDetailList"
                            ItemsSource="{Binding PaymentDetails}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedPaymentDetail}"
                            SelectionChangedCommand="{Binding PaymentDetailChangedCommand}"
                            Grid.Row="1">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PaymentDetailModel">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                <SwipeItem IconImageSource="delete"
                                           Command="{Binding BindingContext.DeletePaymentDetailCommand, Source={x:Reference PaymentDetailSelectorView}}"
                                           CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Style="{StaticResource CardStyle}">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Bank}" />
                                    <Label Text="{Binding AccountHolder}" />
                                    <Label Text="{Binding SortCode}" />
                                    <Label Text="{Binding AccountNumber}" />
                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentView>
</ContentPage>