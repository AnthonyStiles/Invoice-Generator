<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Invoice_Generator.Models"
             xmlns:local="clr-namespace:Invoice_Generator.ViewModels.Invoice"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Invoice_Generator.Views.Invoice.WorkEdit"
             x:DataType="local:WorkEditViewModel"
             x:Name="WorkEditView">
    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="check"
                     Command="{Binding NavigateNextCommand }" />
    </ContentPage.ToolbarItems>
    <ContentPage.Content>
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, *"
              ColumnDefinitions="*, Auto, Auto"
              Padding="30"
              RowSpacing="20"
              ColumnSpacing="10">

            <Label Grid.ColumnSpan="3"
                   Text="Add items the recipient is being invoiced for." />

            <DatePicker Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Margin="0,10,0,0"
                        MinimumDate="01/01/2000"
                        MaximumDate="12/31/2040"
                        Date="{Binding Work.Completed}" />

            <Entry x:Name="DescriptionEntry"
                   Grid.Row="2"
                   Placeholder="Description"
                   Text="{Binding Work.Description}"
                   MaxLength="200"
                   ReturnType="Next"
                   ReturnCommand="{Binding Source={x:Reference HoursEntry}, Path=Focus}" />

            <Entry x:Name="HoursEntry"
                   Grid.Row="2"
                   Grid.Column="1"
                   Placeholder="Hours"
                   Keyboard="Numeric"
                   WidthRequest="80"
                   Text="{Binding Work.Hours}"
                   ReturnType="Next"
                   ReturnCommand="{Binding Source={x:Reference AmountEntry}, Path=Focus}" />

            <Entry x:Name="AmountEntry"
                   Grid.Row="2"
                   Grid.Column="2"
                   Placeholder="Amount"
                   Keyboard="Numeric"
                   WidthRequest="100"
                   Text="{Binding Work.Amount}"
                   ReturnType="Done"
                   ReturnCommand="{Binding AddWorkCommand}" />

            <Button Grid.Row="3"
                    Grid.ColumnSpan="3"
                    Text="Add"
                    Command="{Binding AddWorkCommand}"
                    Margin="0,10,0,10" />

            <CollectionView Grid.Row="4"
                            Grid.ColumnSpan="3"
                            SelectionMode="None"
                            ItemsSource="{Binding Invoice.Work}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkGroupModel">
                        <Border Style="{StaticResource CardStyle}">
                            <Grid RowDefinitions="Auto, *"
                                  RowSpacing="12">
                                <Label Text="{Binding Date, StringFormat='{0:D}'}" />
                                <CollectionView Grid.Row="1"
                                                SelectionMode="None"
                                                ItemsSource="{Binding Work}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:WorkModel">
                                            <Grid ColumnDefinitions="*, Auto, Auto, Auto"
                                                  Padding="0,8"
                                                  ColumnSpacing="10">
                                                <Label Text="{Binding Description}" VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding Hours, StringFormat='{0} hrs'}"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="2"
                                                       Text="{Binding Amount, StringFormat='{0:C}'}"
                                                       VerticalOptions="Center"
                                                       WidthRequest="80" />
                                                <ImageButton Grid.Column="3"
                                                             Source="delete"
                                                             Command="{Binding BindingContext.DeleteWorkCommand, Source={x:Reference WorkEditView}}"
                                                             CommandParameter="{Binding .}"
                                                             HeightRequest="24"
                                                             WidthRequest="24"
                                                             VerticalOptions="Center">
                                                    <ImageButton.Behaviors>
                                                        <toolkit:IconTintColorBehavior
                                                            TintColor="{AppThemeBinding Light={StaticResource Red}, Dark={StaticResource LightRed}}" />
                                                    </ImageButton.Behaviors>
                                                </ImageButton>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentPage.Content>
</ContentPage>