<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Invoice_Generator.ViewModels.Invoice"
             x:Class="Invoice_Generator.Views.Invoice.AddressToEdit"
             x:DataType="local:AddressToEditViewModel">
    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="check" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>
    <ScrollView Padding="30">
        <VerticalStackLayout Spacing="30">
            <Label Text="Add details used for the recipient." />
            <VerticalStackLayout Spacing="20">
                <Entry x:Name="NameEntry"
                       Placeholder="Name"
                       Text="{Binding Address.Name}"
                       MaxLength="50"
                       ReturnType="Next"
                       ReturnCommand="{Binding Source={x:Reference Line1Entry}, Path=Focus}" />
                <Entry x:Name="Line1Entry"
                       Placeholder="Line 1"
                       Text="{Binding Address.Line1}"
                       MaxLength="50"
                       ReturnType="Next"
                       ReturnCommand="{Binding Source={x:Reference Line2Entry}, Path=Focus}" />
                <Entry x:Name="Line2Entry"
                       Placeholder="Line 2"
                       Text="{Binding Address.Line2}"
                       MaxLength="50"
                       ReturnType="Next"
                       ReturnCommand="{Binding Source={x:Reference PostCodeEntry}, Path=Focus}" />
                <Entry x:Name="PostCodeEntry"
                       Placeholder="Post Code"
                       Text="{Binding Address.PostCode}"
                       MaxLength="8"
                       ReturnType="Done"
                       ReturnCommand="{Binding SaveCommand}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>