<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Invoice_Generator.ViewModels.Settings"
             x:Class="Invoice_Generator.Views.Settings.Settings"
             x:DataType="viewmodels:SettingsViewModel">
    <Grid ColumnDefinitions="*"
          RowDefinitions="Auto, Auto"
          Padding="30,30"
          RowSpacing="20">
        <Button Text="View Privacy Policy"
                Command="{Binding OpenPrivacyPolicyCommand}" />
        <Button Grid.Row="1" 
                Text="View Licenses"
                Command="{Binding OpenLicensesCommand}" />
    </Grid>
</ContentPage>
