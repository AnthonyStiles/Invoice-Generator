<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Invoice_Generator.Models"
             xmlns:local="clr-namespace:Invoice_Generator.ViewModels"
             x:Class="Invoice_Generator.Views.WorkEdit"
             x:DataType="local:WorkEditViewModel"
             x:Name="WorkEditView">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Next"
                     IconImageSource=""
                     Command="{Binding NavigateNextCommand }" />
    </ContentPage.ToolbarItems>
    <ContentPage.Content>
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, *"
              ColumnDefinitions="*, Auto, Auto"
              Padding="30"
              RowSpacing="20"
              ColumnSpacing="10">

            <Label Grid.ColumnSpan="3"
                   Text="What work is being invoiced?" />

            <DatePicker Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Margin="0,10,0,0"
                        MinimumDate="01/01/2000"
                        MaximumDate="12/31/2040"
                        Date="{Binding Work.Completed}" />

            <Entry Grid.Row="2"
                   Placeholder="Description"
                   Text="{Binding Work.Description}"
                   MaxLength="200" />

            <Entry Grid.Row="2"
                   Grid.Column="1"
                   Placeholder="Hours"
                   Keyboard="Numeric"
                   WidthRequest="80"
                   Text="{Binding Work.Hours}" />

            <Entry Grid.Row="2"
                   Grid.Column="2"
                   Placeholder="Amount"
                   Keyboard="Numeric"
                   WidthRequest="100"
                   Text="{Binding Work.Amount}" />

            <Button Grid.Row="3"
                    Grid.ColumnSpan="3"
                    Text="Add"
                    Command="{Binding AddWorkCommand}"
                    Margin="0,10,0,10" />

            <CollectionView Grid.Row="4"
                            Grid.ColumnSpan="3"
                            SelectionMode="None"
                            ItemsSource="{Binding Invoice.Work}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkGroupModel">
                        <Border Style="{StaticResource CardStyle}">
                            <Grid RowDefinitions="Auto, *"
                                  RowSpacing="12">
                                <Label Text="{Binding Date, StringFormat='{0:D}'}" />
                                <CollectionView Grid.Row="1"
                                                SelectionMode="None"
                                                ItemsSource="{Binding Work}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:WorkModel">
                                            <SwipeView>
                                                <SwipeView.RightItems>
                                                    <SwipeItems>
                                                        <SwipeItem Text="Delete"
                                                                   Command="{Binding BindingContext.DeleteWorkCommand, Source={x:Reference WorkEditView}}"
                                                                   CommandParameter="{Binding .}" />
                                                    </SwipeItems>
                                                </SwipeView.RightItems>
                                                <Grid ColumnDefinitions="*, Auto, Auto"
                                                      Padding="0,8">
                                                    <Label Text="{Binding Description}" VerticalOptions="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Hours, StringFormat='{0} hrs'}"
                                                           VerticalOptions="Center"
                                                           Margin="10,0" />
                                                    <Label Grid.Column="2"
                                                           HorizontalTextAlignment="End"
                                                           Text="{Binding Amount, StringFormat='{0:C}'}"
                                                           VerticalOptions="Center" />
                                                </Grid>
                                            </SwipeView>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentPage.Content>
</ContentPage>