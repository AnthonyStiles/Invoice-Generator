<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Invoice_Generator.Models"
             xmlns:local="clr-namespace:Invoice_Generator.ViewModels"
             x:Class="Invoice_Generator.Views.WorkEdit"
             x:DataType="local:WorkEditViewModel"
             x:Name="WorkEditView">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Next"
                     IconImageSource=""
                     Command="{Binding NavigateNextCommand }"/>
    </ContentPage.ToolbarItems>
    <ContentPage.Content>
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, *"
              ColumnDefinitions="*, Auto, Auto"
              Padding="50"
              RowSpacing="15"
              ColumnSpacing="10">
            
            <Label Grid.ColumnSpan = "5"
                   Text="What work is being invoiced?"/>
            
            <DatePicker Grid.Row="1"
                        Margin="0,50,0,0"
                        MinimumDate="01/01/2000"
                        MaximumDate="12/31/2040"
                        Date="{Binding Work.Completed}"/>

            <Entry Grid.Row="2"
                   Placeholder="Description"
                   Text="{Binding Work.Description}"/>
            
            <Entry Grid.Row="2"
                   Grid.Column="1" 
                   Placeholder="Hours"
                   Keyboard="Numeric"
                   Text="{Binding Work.Hours}"/>
            
            <Entry Grid.Row="2"
                   Grid.Column="2"
                   Placeholder="Amount"
                   Keyboard="Numeric"
                   Text="{Binding Work.Amount}"/>

            <Button Grid.Row="3"
                    Grid.ColumnSpan="3"
                    Text="Add"
                    Command="{Binding AddWorkCommand}"
                    Margin="0,0,0,20"/>

            <CollectionView Grid.Row="4"
                            Grid.ColumnSpan="3"
                            SelectionMode="None"
                            ItemsSource="{Binding WorkList}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkGroupModel">
                        <Border>
                            <Grid RowDefinitions="Auto, *"
                              RowSpacing="15">
                                <Label Text="{Binding Date, StringFormat='{0:d}'}"/>
                                <CollectionView Grid.Row="1"
                                                SelectionMode="None"
                                                ItemsSource="{Binding Work}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:WorkModel">
                                            <SwipeView>
                                                <SwipeView.RightItems>
                                                    <SwipeItems>
                                                        <SwipeItem Text="Delete"
                                                                   BackgroundColor="LightPink"
                                                                   Command="{Binding BindingContext.DeleteWorkCommand, Source={x:Reference WorkEditView}}"
                                                                   CommandParameter="{Binding .}" />
                                                    </SwipeItems>
                                                </SwipeView.RightItems>
                                                <Grid ColumnDefinitions="2*, 1*, 1*"
                                                      Padding="10">
                                                    <Label Text="{Binding Description}"/>
                                                    <HorizontalStackLayout Grid.Column="1"
                                                                           Spacing="5"
                                                                           HorizontalOptions="End">
                                                        <Label Text="{Binding Hours}"/>
                                                        <Label Text="Hours"/>
                                                    </HorizontalStackLayout>
                                                    <Label Grid.Column="2"
                                                           HorizontalTextAlignment="End"
                                                           Text="{Binding Amount, StringFormat='{0:C}'}"/>
                                                </Grid>
                                            </SwipeView>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentPage.Content>
</ContentPage>